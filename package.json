{
  "name": "pageant-tabulator",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:lan": "concurrently \"npm run dev --prefix server\" \"npm run dev:lan --prefix client\"",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "pm2:start": "npm run build && pm2 start server/ecosystem.config.cjs",
    "pm2:stop": "pm2 stop pageant-server",
    "pm2:restart": "pm2 restart pageant-server",
    "pm2:logs": "pm2 logs pageant-server",
    "pm2:status": "pm2 status",
    "backup": "node server/scripts/backup.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Local-first pageantry scoring system",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
