# Server port
PORT=3000

# CORS: set to the URL of your frontend (Vite dev server or deployed URL)
CLIENT_ORIGIN=http://localhost:5173

# Admin authentication secret (required for admin dashboard access)
# Change this to a strong secret before deploying to production
ADMIN_SECRET=your-secure-admin-secret-here

# JWT configuration for admin sessions
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=24h

# Database configuration (optional - defaults provided)
# DB_DIR=./data
# DB_PATH=./data/pageant.db

# Report cache TTL (optional - default 5 minutes)
# REPORT_CACHE_TTL_MS=300000
